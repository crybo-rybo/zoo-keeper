DOXYFILE_ENCODING      = UTF-8
PROJECT_NAME           = "@PROJECT_NAME@"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
PROJECT_BRIEF          = "C++23 agentic wrapper around llama.cpp"
OUTPUT_DIRECTORY       = "@ZOO_DOXYGEN_OUTPUT_DIR@"
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = NO

BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = NO
ALWAYS_DETAILED_SEC    = NO
INLINE_INHERITED_MEMB  = NO
FULL_PATH_NAMES        = YES
STRIP_FROM_PATH        = @ZOO_DOXYGEN_STRIP_PATHS_FORMATTED@
SHORT_NAMES            = NO
JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES
INHERIT_DOCS           = YES
SEPARATE_MEMBER_PAGES  = NO
TAB_SIZE               = 4

OPTIMIZE_OUTPUT_FOR_C  = NO
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
CPP_CLI_SUPPORT        = NO
SIP_SUPPORT            = NO
IDL_PROPERTY_SUPPORT   = YES
SUBGROUPING            = YES

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_PRIV_VIRTUAL   = NO
EXTRACT_PACKAGE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_LOCAL_METHODS  = NO
EXTRACT_ANON_NSPACES   = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
HIDE_IN_BODY_DOCS      = NO
INTERNAL_DOCS          = NO

CASE_SENSE_NAMES       = YES
SHOW_INCLUDE_FILES     = YES
SHOW_USED_FILES        = YES
SHOW_FILES             = YES
SHOW_NAMESPACES        = YES
SHOW_HEADERFILE        = YES
VERBATIM_HEADERS       = YES

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
WARN_AS_ERROR          = NO
QUIET                  = YES

INPUT                  = @ZOO_DOXYGEN_INPUTS_FORMATTED@
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.hpp *.h *.cpp
RECURSIVE              = YES
EXCLUDE                = @ZOO_DOXYGEN_EXCLUDES_FORMATTED@
EXCLUDE_PATTERNS       = */extern/* */build/* */tests/cmake_test_discovery_*
EXCLUDE_SYMLINKS       = NO
EXCLUDE_SYMBOLS        = zoo::tools::detail

USE_MDFILE_AS_MAINPAGE = "@PROJECT_SOURCE_DIR@/README.md"

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
REFERENCES_LINK_SOURCE = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_DYNAMIC_SECTIONS  = YES
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
ENUM_VALUES_PER_LINE   = 4

GENERATE_LATEX         = NO
GENERATE_XML           = YES
XML_OUTPUT             = xml
XML_PROGRAMLISTING     = NO

HAVE_DOT               = @ZOO_DOXYGEN_HAVE_DOT@
DOT_PATH               = "@ZOO_DOXYGEN_DOT_PATH@"
CLASS_GRAPH            = @ZOO_DOXYGEN_HAVE_DOT@
COLLABORATION_GRAPH    = @ZOO_DOXYGEN_HAVE_DOT@
GROUP_GRAPHS           = @ZOO_DOXYGEN_HAVE_DOT@
UML_LOOK               = @ZOO_DOXYGEN_HAVE_DOT@
TEMPLATE_RELATIONS     = @ZOO_DOXYGEN_HAVE_DOT@
INCLUDE_GRAPH          = @ZOO_DOXYGEN_HAVE_DOT@
INCLUDED_BY_GRAPH      = @ZOO_DOXYGEN_HAVE_DOT@
CALL_GRAPH             = @ZOO_DOXYGEN_HAVE_DOT@
CALLER_GRAPH           = @ZOO_DOXYGEN_HAVE_DOT@
DOT_MULTI_TARGETS      = @ZOO_DOXYGEN_HAVE_DOT@
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = @ZOO_DOXYGEN_HAVE_DOT@
DOT_NUM_THREADS        = 0
