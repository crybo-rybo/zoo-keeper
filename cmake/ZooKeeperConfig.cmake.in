@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(llama CONFIG)

include("${CMAKE_CURRENT_LIST_DIR}/ZooKeeperTargets.cmake")

# llama is a private build dependency of zoo but consumers of the static library
# still need it on the link line.  The export set intentionally omits it (llama
# is not in our export set), so we append it here after find_dependency succeeds.
if(TARGET ZooKeeper::zoo AND TARGET llama)
    set_property(TARGET ZooKeeper::zoo APPEND PROPERTY
        INTERFACE_LINK_LIBRARIES llama
    )
endif()

check_required_components(ZooKeeper)
