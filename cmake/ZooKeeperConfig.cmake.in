@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# ggml-config.cmake references OpenMP::OpenMP_C even when the consumer only
# enables CXX. Find OpenMP first and, if C language is not enabled, create a
# stub so that ggml's set_target_properties succeeds.
if("@ZOO_BUILD_GGML_OPENMP_ENABLED@" STREQUAL "ON")
    find_dependency(OpenMP)
    if(NOT TARGET OpenMP::OpenMP_C AND TARGET OpenMP::OpenMP_CXX)
        add_library(OpenMP::OpenMP_C INTERFACE IMPORTED GLOBAL)
        set_property(TARGET OpenMP::OpenMP_C PROPERTY
            INTERFACE_LINK_LIBRARIES OpenMP::OpenMP_CXX)
    endif()
endif()

find_dependency(llama CONFIG)
find_dependency(nlohmann_json 3.11 CONFIG)

if(NOT TARGET ZooKeeper::llama AND TARGET llama)
    add_library(ZooKeeper::llama INTERFACE IMPORTED)
    # libcommon.a is installed by zoo_install_llama_common() in
    # cmake/ZooKeeperLlama.cmake. Upstream llama.cpp does not export it from
    # its own CMake package, so consumers reach it by path through us.
    set_property(TARGET ZooKeeper::llama PROPERTY
        INTERFACE_LINK_LIBRARIES
            "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_LIBDIR@/libcommon.a"
            llama
    )
endif()

if(NOT TARGET ZooKeeper::nlohmann_json)
    add_library(ZooKeeper::nlohmann_json INTERFACE IMPORTED)
    set_property(TARGET ZooKeeper::nlohmann_json PROPERTY
        INTERFACE_LINK_LIBRARIES nlohmann_json::nlohmann_json
    )
endif()

include("${CMAKE_CURRENT_LIST_DIR}/ZooKeeperTargets.cmake")

check_required_components(ZooKeeper)
