@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

if("@ZOO_BUILD_GGML_OPENMP_ENABLED@" STREQUAL "ON")
    find_dependency(OpenMP)
endif()

if("@ZOO_BUILD_GGML_BLAS_ENABLED@" STREQUAL "ON")
    find_dependency(BLAS)
endif()

if(NOT TARGET ZooKeeper::nlohmann_json)
    add_library(ZooKeeper::nlohmann_json INTERFACE IMPORTED)
    set_property(TARGET ZooKeeper::nlohmann_json PROPERTY
        INTERFACE_INCLUDE_DIRECTORIES "@json_SOURCE_DIR@/include"
    )
endif()

set(_zoo_build_llama_link_libraries "@ZOO_BUILD_LLAMA_LINK_LIBRARIES@")
if("@ZOO_BUILD_GGML_OPENMP_ENABLED@" STREQUAL "ON")
    list(APPEND _zoo_build_llama_link_libraries OpenMP::OpenMP_CXX)
endif()
set(_zoo_build_blas_libraries "@ZOO_BUILD_BLAS_LIBRARIES@")
if(_zoo_build_blas_libraries)
    list(APPEND _zoo_build_llama_link_libraries ${_zoo_build_blas_libraries})
endif()

if(NOT TARGET ZooKeeper::zoo)
    add_library(ZooKeeper::zoo STATIC IMPORTED)
    set_target_properties(ZooKeeper::zoo PROPERTIES
        IMPORTED_LOCATION "@ZOO_BUILD_ZOO_LOCATION@"
        INTERFACE_COMPILE_FEATURES "cxx_std_23"
        INTERFACE_INCLUDE_DIRECTORIES "@ZOO_BUILD_INTERFACE_INCLUDE_DIRECTORIES@"
        INTERFACE_LINK_LIBRARIES "ZooKeeper::llama;ZooKeeper::nlohmann_json"
    )
endif()

if(NOT TARGET ZooKeeper::llama)
    add_library(ZooKeeper::llama INTERFACE IMPORTED)
    set_property(TARGET ZooKeeper::llama PROPERTY
        INTERFACE_LINK_LIBRARIES "${_zoo_build_llama_link_libraries}"
    )
    set(_zoo_build_blas_linker_flags "@ZOO_BUILD_BLAS_LINKER_FLAGS@")
    if(_zoo_build_blas_linker_flags)
        set_property(TARGET ZooKeeper::llama PROPERTY
            INTERFACE_LINK_OPTIONS "${_zoo_build_blas_linker_flags}"
        )
    endif()
endif()

if(NOT TARGET ZooKeeper::zoo_core)
    add_library(ZooKeeper::zoo_core INTERFACE IMPORTED)
    set_property(TARGET ZooKeeper::zoo_core PROPERTY
        INTERFACE_LINK_LIBRARIES ZooKeeper::zoo
    )
endif()

check_required_components(ZooKeeper)
